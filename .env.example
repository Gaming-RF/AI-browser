# Environment Variables Template
# Copy this to .env and fill in your actual values.
# Settings here override config/config.yaml.

# ── AI Provider ─────────────────────────────────────────
AI_PROVIDER=openai              # or "anthropic"
AI_MODEL=gpt-4                  # e.g. gpt-4o, claude-3-opus-20240229, llama3

# ── API Keys ────────────────────────────────────────────
# Leave blank if using a local model server.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Custom API Endpoint (local / self-hosted models) ───
# Ollama:    http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# vLLM:      http://localhost:8000/v1
API_BASE_URL=

# ── Browser ─────────────────────────────────────────────
HEADLESS_MODE=true              # false to see the browser window
BROWSER_SLOW_MO=0               # ms delay between actions
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900

# ── Execution ───────────────────────────────────────────
MAX_STEPS=15                    # max autonomous steps per task
TASK_TIMEOUT=300                # seconds
MAX_RETRIES=3

# ── Vision ──────────────────────────────────────────────
# Sends a screenshot to the model at each step.
# Requires a vision-capable model (gpt-4o, claude-3-*, llava).
VISION_MODE=false

# ── Memory ──────────────────────────────────────────────
MEMORY_DB_PATH=memory.db
