{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.gamingrf.aibrowser",
    "productName": "AI Browser",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Gaming-RF",
        "repo": "AI-browser"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "extraFiles": [
      {
        "from": "../dist",
        "to": "backend",
        "filter": [
          "backend.exe",
          "backend"
        ]
      }
    ]
  },
  "keywords": [],
  "author": "Gaming-RF <gamingrf@example.com>",
  "homepage": "https://github.com/Gaming-RF/AI-browser",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.3.9"
  }
}
